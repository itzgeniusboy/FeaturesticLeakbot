import time
import requests

BOT_TOKEN = "8775696477:AAEnN0Onmw09_m3UJBLPyGCg389yLR4LReI"
CHANNEL_ID = -1003201511422
API_URL = f"https://api.telegram.org/bot{BOT_TOKEN}/"

print("--- NATIVE BOT ENGINE STARTED ---")

def send_welcome(chat_id):
    try:
        bot_info = requests.get(API_URL + "getMe").json()
        bot_username = bot_info["result"]["username"]
        admin_url = f"https://t.me/{bot_username}?startchannel=true&admin=post_messages+edit_messages+delete_messages"
        
        text = "👋 **Welcome!**\n\nFiles ko bina caption ke channel me forward karne ke liye mujhe admin banayein:"
        reply_markup = {
            "inline_keyboard": [[{"text": "➕ Add Bot to Channel", "url": admin_url}]]
        }
        
        requests.post(API_URL + "sendMessage", json={
            "chat_id": chat_id, "text": text, "parse_mode": "Markdown", "reply_markup": reply_markup
        })
    except Exception as e:
        print(f"Start error: {e}")

def handle_media(message):
    try:
        chat_id = message["chat"]["id"]
        file_id = None
        method = None
        payload_key = None

        if "document" in message:
            method = "sendDocument"
            file_id = message["document"]["file_id"]
            payload_key = "document"
        elif "video" in message:
            method = "sendVideo"
            file_id = message["video"]["file_id"]
            payload_key = "video"
        elif "photo" in message:
            method = "sendPhoto"
            file_id = message["photo"][-1]["file_id"] # Best quality
            payload_key = "photo"
        elif "audio" in message:
            method = "sendAudio"
            file_id = message["audio"]["file_id"]
            payload_key = "audio"
        elif "voice" in message:
            method = "sendVoice"
            file_id = message["voice"]["file_id"]
            payload_key = "voice"

        if method and file_id:
            # Strictly NO caption forwarded (caption=None / Empty)
            res = requests.post(API_URL + method, json={
                "chat_id": CHANNEL_ID,
                payload_key: file_id
            }).json()
            
            if res.get("ok"):
                requests.post(API_URL + "sendMessage", json={
                    "chat_id": chat_id, "text": "✅ Successfully Uploaded to Channel (Bina kisi text ke)!"
                })
            else:
                requests.post(API_URL + "sendMessage", json={
                    "chat_id": chat_id, "text": f"❌ Failed: {res.get('description')}"
                })
    except Exception as e:
        print(f"Media upload error: {e}")

if __name__ == "__main__":
    offset = 0
    start_time = time.time()
    
    # 5 ghante ka lightweight performance runner loop
    while time.time() - start_time < 18000:
        try:
            response = requests.get(API_URL + "getUpdates", params={"offset": offset, "timeout": 30}, timeout=35).json()
            if "result" in response:
                for update in response["result"]:
                    offset = update["update_id"] + 1
                    if "message" in update:
                        msg = update["message"]
                        text = msg.get("text", "")
                        
                        if text.startswith("/start"):
                            send_welcome(msg["chat"]["id"])
                        else:
                            handle_media(msg)
        except Exception as e:
            print(f"Network glitch, retrying... {e}")
            time.sleep(2)
